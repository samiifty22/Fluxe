// Prisma schema for Fluxe SaaS (Postgres — Vercel Postgres in production, same DB for local dev)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String    @id @default(cuid())
  name        String    @unique
  ownerId     String?
  plan        String    @default("trial") // trial | monthly | yearly | expired
  status      String    @default("active")
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  users       User[]
  integrations Integration[]
  billing     Billing?
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          String    @default("member")
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

// ── NextAuth (Prisma adapter) ─────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Integration {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  config    String   // encrypted JSON string
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Billing {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String    @default("trialing") // trialing | active | past_due | canceled
  plan                 String? // monthly | yearly
  currentPeriodEnd     DateTime?
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
}

model PipelineItem {
  id           String   @id @default(cuid())
  name         String
  sellPrice    Float?
  sourcingCost Float?
  margin       Float?
  currentStage String   @default("supplier")
  stages       String   // JSON string: { [stageId]: { status, data, completedAt } }
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
